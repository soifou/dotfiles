#!/usr/bin/env sh

# Use a filemanager to add file(s) as attachments in neomutt
# Inspired by https://github.com/neomutt/neomutt/discussions/4603

fm_supported="lf yazi elio"

pick_cmd() {
    case "$1" in
        lf) echo "lf -selection-path /dev/stdout" ;;
        yazi) echo "yazi --chooser-file /dev/stdout" ;;
        elio) echo "elio --chooser-file /dev/stdout" ;;
        *)
            echo "Unsupported file picker: $1" >&2
            return 1
            ;;
    esac
}

detect_picker() {
    # explicit
    if [ -n "${FILEMANAGER:-}" ] && command -v "$FILEMANAGER" > /dev/null 2>&1; then
        echo "$FILEMANAGER"
        return 0
    fi

    # fallback
    for p in $fm_supported; do
        command -v "$p" > /dev/null 2>&1 && { echo "$p"; return 0; }
    done

    return 1
}

fm=$(detect_picker) || {
    echo "No file picker found ($fm_supported)" >&2
    exit 1
}

cmd=$(pick_cmd "$fm") || exit 1

files=$($cmd)
[ $? -ne 0 ] && exit 1
[ -z "$files" ] && exit 0

printf "%s\n" "$files" | awk 'BEGIN { printf "push " } { printf "<attach-file>\"%s\"<enter>", $0 }'
