# Default config: https://yamllint.readthedocs.io/en/latest/configuration.html#default-configuration
extends: default

rules:
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1
  line-length:
    max: 120
    level: warning
