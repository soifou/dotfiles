#!/usr/bin/env sh

# Nvim as a kitty scrollback pager, require nvim 0.12+. |terminal-scrollback-pager|
# Usage from kitty config: scrollback_pager kitty-scrollback-pager 'INPUT_LINE_NUMBER' 'CURSOR_LINE' 'CURSOR_COLUMN'
# Keeps exact scroll position (for history) and cursor position (for prompt), smoother on the eyes.

INPUT_LINE_NUMBER=${1:-0}
CURSOR_LINE=${2:-1}
CURSOR_COLUMN=${3:-1}

TARGET_LINE=$((INPUT_LINE_NUMBER + CURSOR_LINE))
[ "$CURSOR_COLUMN" -ne 0 ] && {
    cmd=zb
    CURSOR_COLUMN=$((CURSOR_COLUMN + 1))
    TARGET_LINE=$((TARGET_LINE - 1))
} || cmd=zt
callback="execute('call cursor(min([line(\"$\"), max([1, $TARGET_LINE])]), $CURSOR_COLUMN) | normal! $cmd')"

exec nvim -u NONE \
    --cmd 'nnoremap q ZQ' \
    +'call nvim_open_term(0, {})' \
    +"call timer_start(10, {-> $callback })" \
    +'set ei=FileType ls=0 ch=0 cb=unnamed ma ul=100' \
    +'autocmd TextYankPost * silent! lua vim.hl.on_yank {higroup="Visual"}'
